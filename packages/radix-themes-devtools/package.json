{
  "name": "radix-themes-devtools",
  "version": "0.1.0",
  "description": "TanStack Devtools plugin for Radix UI Themes — customize your theme in real time from the devtools panel",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@radix-ui/themes": ">=3.0.0",
    "@tanstack/devtools-event-client": ">=0.0.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@radix-ui/themes": "^3.2.1",
    "@tanstack/devtools-event-client": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.4.0"
  },
  "keywords": [
    "radix",
    "radix-ui",
    "radix-themes",
    "devtools",
    "tanstack",
    "tanstack-devtools",
    "theme",
    "react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JavierBrooktec/radix-themes-devtools"
  },
  "homepage": "https://github.com/JavierBrooktec/radix-themes-devtools#readme",
  "bugs": {
    "url": "https://github.com/JavierBrooktec/radix-themes-devtools/issues"
  }
}
